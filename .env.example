# SaviorAI Environment Configuration
# Copy this file to .env and fill in your actual values

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
# PostgreSQL connection string (asyncpg driver required)
# Format: postgresql+asyncpg://username:password@host:port/database
# Example (Railway): postgresql+asyncpg://postgres:xxx@containers-us-west-xxx.railway.app:7432/railway
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/SaviorAI

# =====================================================
# OPENAI API CONFIGURATION
# =====================================================
# OpenAI API key for GPT-4o access
# Get your key at: https://platform.openai.com/api-keys
# Required for: Sentiment analysis, alert generation, cohort reasoning
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================================================
# TWILIO CONFIGURATION (WhatsApp)
# =====================================================
# Twilio account credentials
# Get these at: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio WhatsApp sender number
# Sandbox (testing): whatsapp:+14155238886
# Production: whatsapp:+1234567890 (your verified number)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# =====================================================
# DASHBOARD API CONFIGURATION
# =====================================================
# API key for dashboard authentication
# Use a secure random string in production
# Generate: openssl rand -hex 32
DASHBOARD_API_KEY=SaviorAI_dev_key_2024

# =====================================================
# DEPLOYMENT CONFIGURATION
# =====================================================
# Environment mode
# Options: development, staging, production
ENVIRONMENT=development

# Server host and port
# Use 0.0.0.0 to allow external connections (e.g., ngrok)
HOST=0.0.0.0
PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# =====================================================
# SCHEDULER CONFIGURATION (Optional)
# =====================================================
# Enable daily check-in scheduler
# Set to "false" to disable scheduled prompts
SCHEDULER_ENABLED=true

# Daily check-in time (24-hour format, UTC)
# Example: 09:00 = 2:30 PM IST (UTC+5:30)
CHECKIN_TIME=09:00

# =====================================================
# LOGGING & MONITORING (Optional)
# =====================================================
# Log level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Sentry DSN for error tracking (optional)
# Get from: https://sentry.io/
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# =====================================================
# FEATURE FLAGS (Optional)
# =====================================================
# Enable/disable specific agents (for testing)
ENABLE_HMM_AGENT=true
ENABLE_ADVERSARIAL_AGENT=true
ENABLE_COHORT_AGENT=true

# Minimum students required for cohort detection
MIN_COHORT_SIZE=5

# Cohort anomaly threshold (percentage of batch affected)
COHORT_THRESHOLD=0.40

# =====================================================
# DEMO MODE CONFIGURATION
# =====================================================
# Enable demo mode to use email instead of WhatsApp for Level 3 interventions
DEMO_MODE=true

# Email configuration for demo alerts (Gmail SMTP)
DEMO_COUNSELLOR_EMAIL=your.email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password_here

# How to get Gmail app password:
# 1. Enable 2-factor authentication on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Create app password for "Mail" on "Other (Custom name)"
# 4. Copy the 16-character password (no spaces)

# =====================================================
# NOTES
# =====================================================
# 1. Never commit the actual .env file to git
# 2. Keep production secrets secure (use Railway secrets, not .env in production)
# 3. Rotate API keys regularly
# 4. Use different keys for development and production
# 5. For Railway deployment, set these as environment variables in the dashboard

